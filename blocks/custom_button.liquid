{% liquid
  assign btn_style   = block.settings.custom_button_style
  assign width_mode  = block.settings.width_mode
  assign content_height  = block.settings.content_height
  assign label       = block.settings.custom_button_label
  assign btn_url     = block.settings.custom_button_url
  assign custom_clr  = block.settings.enable_custom_colors
  assign show_icon   = block.settings.show_icon
  assign open_new    = block.settings.open_new_tab
%}

{% comment %} ── Build the <a> attributes cleanly ── {% endcomment %}
{% capture link_attrs %}
  {% if btn_url != blank %}href="{{ btn_url }}"{% endif %}
  {% if open_new %} target="_blank" rel="noopener noreferrer"{% endif %}
  {% if block.settings.aria_label != blank %} aria-label="{{ block.settings.aria_label | escape }}"{% endif %}
{% endcapture %}

<div class= "custom_button--{{ block.id }} custom_button_{{ width_mode }}" 
{{ block.shopify_attributes }}>
    
  
    {% if label != blank %}
        <a class="custom_button custom_button_{{ btn_style }} {% if custom_clr %} custom-button--custom {% endif %}" {{ link_attrs }}
        style="padding: var(--button_spacing); --button-radius: {{ block.settings.button_radius }}px;
        {% if block.settings.enable_custom_colors %} --button-bg: {{ block.settings.button_bg }};
        --button-text: {{ block.settings.button_text }}; --button-border-color: {{ block.settings.button_border_color }}; --button-border-width: {{ block.settings.button_border_size }}px;
        --button-border-style: {{ block.settings.button_border_style }}; {% endif %}"> 

            <span class="custom_btn_text"> {{ label }} </span>  

            {% if show_icon %}
            <span class="custom_btn_icon" aria-hidden="true">
                <svg width="20" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" 
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>  </svg>
                {% comment %} <img src="{{ 'Vector 1.svg' | asset_url }}" alt=""> {% endcomment %}
            </span>
            {% endif %}
        </a>
    {% endif %}
    

</div>

<style>
    
    /* ── Wrapper: width modes ──────────────────────────────────────── */
    .custom_button--{{ block.id }}{
    height: {{content_height}};
    display: flex;               /* keeps child <a> stretchable */
    align-items: stretch;
    } 

   .custom_button--{{ block.id }}.custom_button_fit-content {
    width: fit-content;
    }

   .custom_button--{{ block.id }}.custom_button_full-width {
    width: 100%;
    }

   .custom_button--{{ block.id }}.custom_button_custom {
    max-width: {{ block.settings.max_width }}px;
    width: 100%;
    }

    /* ── Button base ───────────────────────────────────────────────── */
    .custom_button--{{ block.id }} .custom_button{
    display: inline-flex;
    width: 100%;
    max-width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0;
    overflow: hidden;
    white-space: nowrap;
    text-transform: {{ block.settings.text_transform }};
    text-decoration: none;
    transition: all .25s ease;
    font: inherit;
    cursor: pointer;

    /* ── Padding: NOT on link style ── */
    {% if btn_style != 'link' %}
    --button_spacing: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    {% endif %}

    border-radius: var(--button-radius, 999px);
    font-size: clamp(
            {{ block.settings.mobile_min_fontsize }}px,
            calc( {{ block.settings.mobile_min_fontsize }}px + 
            ( {{ block.settings.desktop_max_fontsize }} - {{ block.settings.mobile_min_fontsize }} ) * ((100vw - 320px) / 880)),
            {{ block.settings.desktop_max_fontsize }}px
        );
    font-weight: {{ block.settings.font_weight }};
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    }

    /* Button Style */
    .custom_button--{{ block.id }} .custom_button {
               /* Dawn defaults */
        --btn-bg: rgb(var(--color-button));
        --btn-text: rgb(var(--color-button-text));
        --btn-border-color: rgb(var(--color-button));
        --btn-border-width: 1px;
        --btn-border-style: solid;
    }

 /* ===== Override Defaults When Custom Colors Are Enabled===== */

    .custom_button--{{ block.id }} .custom-button--custom {
         {% if custom_clr %}
      --btn-bg:           {{ block.settings.button_bg }};
      --btn-text:         {{ block.settings.button_text }};
      --btn-border-color: {{ block.settings.button_border_color }};
      --btn-border-width: {{ block.settings.button_border_size }}px;
      --btn-border-style: {{ block.settings.button_border_style }};
    {% endif %}
    }

    /* ── Text & icon animation ─────────────────────────────────────── */
    .custom_button--{{ block.id }} .custom_btn_text {
        display: inline-block;
        transform:  translateX({% if show_icon %}4px{% else %}0{% endif %});
        transition: transform .35s ease;
    }

    .custom_button--{{ block.id }} .custom_btn_icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px; /* fixed width reserved */
        flex-shrink: 0;
        opacity: 0;
        transform: translateX(-4px);
        transition:
            transform 0.35s ease,
            opacity 0.25s ease;
    }

            /* Icon image */
        .custom_btn_icon svg {
        width: 18px;
        min-width: 16px;
        display: block;
        color: currentColor;
        }
    
    .custom_button--{{ block.id }}:hover .custom_btn_text {
        transform: translateX(-4px);
    }
    .custom_button--{{ block.id }}:hover .custom_btn_icon {
        opacity: 1;
        transform: translateX(2px);
    }
    
  
   
    /* ===== SOLID ===== */

    .custom_button--{{ block.id }} .custom_button_solid {
        background: var(--btn-bg);
        color: var(--btn-text);
        border:
            var(--btn-border-width)
            var(--btn-border-style)
            var(--btn-border-color);
        }

    .custom_button--{{ block.id }} .custom_button_solid:hover {
    opacity: 0.88;
    }

    /* ===== OUTLINE ===== */

    .custom_button--{{ block.id }} .custom_button_outline {
    background: transparent;
    color: var(--btn-text);
    border:
        var(--btn-border-width)
        var(--btn-border-style)
        var(--btn-border-color);
    }

    .custom_button--{{ block.id }} .custom_button_outline:hover {
    background: var(--btn-bg);
    color: var(--btn-text);
    }

    /* ===== LINK ===== */

    .custom_button--{{ block.id }} .custom_button_link {
    padding:    0;
    background: transparent;
    border: none;
    color: var(--btn-text);
    }

    .custom_button--{{ block.id }} .custom_button_link:hover {
    text-decoration: underline;
    }

    /* ===== GHOST ===== */

    .custom_button--{{ block.id }} .custom_button_ghost {
    background: rgba(0, 0, 0, 0.06);      /* safe fallback */
    background: color-mix(in srgb, var(--btn-bg) 12%, transparent);
    color: var(--btn-text);
    border:
        var(--btn-border-width)
        var(--btn-border-style)
        transparent;
    }

    .custom_button--{{ block.id }} .custom_button_ghost:hover {
     background: rgba(0, 0, 0, 0.12);
    background: color-mix(in srgb, var(--btn-bg) 22%, transparent);
    }
       
</style>
{%  schema  %} 
{
    "name": "Custom Button",
    "tag": null,
    "settings": [
        { "type": "header", "content": "Width" },
        {
            "type": "select",
            "id": "width_mode",
            "label": "Width",
            "default": "fit-content",
            "options": [
                { "value": "fit-content", "label": "Fit content"},
                { "value": "full-width", "label": "Full width" },
                { "value": "custom", "label": "Custom width" }]
        },
        {
            "type": "select",
            "id": "content_height",
            "label": "Content Height",
            "options": [
                
                { "value": "100%", "label": "Full" },
                { "value": "fit-content", "label": "Fit Content" }
            ],
            "default": "fit-content"
        },
        {
            "type": "range",
            "id": "max_width",
            "label": "Custom width",
            "min": 100,
            "max": 800,
            "step": 10,
            "unit": "px",
            "default": 280,
            "visible_if": "{{ block.settings.width_mode == 'custom' }}"
        },
        { "type": "header", "content": "Link" },
        {
            "type": "url",
            "id": "custom_button_url",
            "label": "Button Url"
        },
        {
            "type": "checkbox",
            "id": "open_new_tab",
            "label": "Open in new tab",
            "default": false
        },
        { "type": "header", "content": "Label" },
        {
            "type": "text",
            "id": "custom_button_label",
            "label": "Button label",
            "default": "Click here",
            "info": "Plain text only — HTML tags are not allowed inside a button label."
        },
        {
            "type": "text",
            "id": "aria_label",
            "label": "Accessibility label (optional)",
            "info": "Screen reader label. Use when the button text alone is not descriptive enough."
        },
        {
            "type": "checkbox",
            "id": "show_icon",
            "label": "Show arrow icon",
            "default": true
        },       
       
        {
            "type": "range",
            "id": "vertical_padding",
            "label": "Vertical Padding",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 17
        },
        {
            "type": "range",
            "id": "horizontal_padding",
            "label": "Horizontal Padding",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 22
        },
        {
            "type": "select",
            "id": "custom_button_style",
            "label": "Button Style",
            "options": [
                { "label": "Solid", "value": "solid" },
                { "label": "Outline", "value": "outline" },
                { "label": "Link", "value": "link" },
                { "value": "ghost", "label": "Ghost" }
            ],
            "default": "solid"
        },
        {
            "type": "range",
            "id": "button_radius",
            "min": 0,
            "max": 100,
            "step": 2,
            "unit": "px",
            "default": 100,
            "label": "Border radius"
        },
        { "type": "header", "content": "Custom colors" },
        {
            "type": "checkbox",
            "id": "enable_custom_colors",
            "label": "Enable custom colors",
            "default": false
        },
        {
            "type": "color",
            "id": "button_bg",
            "label": "Background color",
            "visible_if": "{{ block.settings.enable_custom_colors }}"
        },
        {
            "type": "color",
            "id": "button_text",
            "label": "Text color",
            "visible_if": "{{ block.settings.enable_custom_colors }}"
        },
        {
            "type": "color",
            "id": "button_border_color",
            "label": "Border color",
            "visible_if": "{{ block.settings.enable_custom_colors }}"
        },
        {
            "type": "range",
            "id": "button_border_size",
            "label": "Border Size",
            "min": 0,
            "max": 10,
            "step": 0.5,
            "unit": "px",
            "default": 1,
             "visible_if": "{{ block.settings.enable_custom_colors }}"
        },
        {
            "type": "select",
            "id": "button_border_style",
            "label": "Border Style",
            "default": "solid",
            "options": [
            {"label": "Solid", "value": "solid"},
            {"label": "Dashed", "value": "dashed"},
            {"label": "Dotted", "value": "dotted"},
            {"label": "Double", "value": "double"}
            ],
             "visible_if": "{{ block.settings.enable_custom_colors }}"
        },
         {
            "type": "checkbox",
            "id": "typography",
            "label": "Typography",
            "default": false
        },
        {
            "type": "range",
            "id": "mobile_min_fontsize",
            "label": "Mobile Font Size",
            "min": 18,
            "max": 22,
            "step": 1,
            "unit": "px",
            "default": 20,
            "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "desktop_max_fontsize",
            "label": "Desktop Font Size",
            "min": 20,
            "max": 24,
            "step": 1,
            "unit": "px",
            "default": 20,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "select",
            "id": "font_weight",
            "label": "Font Weight",
            "options": [
                { "value": "300", "label": "Light" },
                { "value": "400", "label": "Regular" },
                { "value": "500", "label": "Medium" },
                { "value": "600", "label": "Semi Bold" },
                { "value": "700", "label": "Bold" }
            ],
            "default": "400",
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "line_height",
            "label": "Line Height",
            "min": 0.8,
            "max": 1.5,
            "step": 0.1,
            "default": 0.9,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "letter_spacing",
            "label": "Letter Spacing",
            "min": -5,
            "max": 20,
            "step": 1,
            "unit": "px",
            "default": 0,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "select",
            "id": "text_transform",
            "label": "Text Transform",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "uppercase", "label": "UPPERCASE" },
                { "value": "lowercase", "label": "lowercase" },
                { "value": "capitalize", "label": "Capitalize" }
        ],
            "default": "none",
             "visible_if": "{{ block.settings.typography }}"
        }  
    ],
    "presets": [
        {"name": "Custom Button"}
    ]
}
{% endschema %} 