{% liquid  
  assign subtitle_color = block.settings.subtitle_color
  assign subtitle_mobilesize = block.settings.subtitle_mobilesize
  assign subtitle_desktopsize = block.settings.subtitle_desktopsize

  assign title_color = block.settings.title_color
  assign title_mobilesize = block.settings.title_mobilesize
  assign title_desktopsize = block.settings.title_desktopsize
 %}

<div class="image-text-slider">
  {% if block.settings.image_link != blank %}
    <a href="{{ block.settings.image_link }}" class="image-text-slider__image-link">
  {% endif %}

    {% if block.settings.image != blank %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.title | escape }}"
        loading="lazy"
        class="image-text-slider__image"
      >
      {% else %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    

  {% if block.settings.image_link != blank %}
    </a>
  {% endif %}

  <!-- OVERLAY -->
    <div class="image-overlay">&nbsp</div>
  

  <div class="image-text-slider__content">
    {% if block.settings.subtitle != blank %}
      <span class="image-text-slider__subtitle">
        {{ block.settings.subtitle }}
      </span>
    {% endif %}

    {% if block.settings.title != blank %}
      <h3 class="image-text-slider__title">
        {{ block.settings.title }}
      </h3>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="image-text-slider__description">
        {{ block.settings.description }}
      </div>
    {% endif %}
  </div>
</div>

<style>
.image-text-slider{
  display:flex;
  flex-direction:column;
  width:100%;
  height:100%;
  overflow:hidden;
  position: relative;
}

.image-text-slider__image-link{
  display:block;
  line-height:0;
}

.image-text-slider__image{
  width:100%;
  /* max-width: 300px; */
  display:block;
  object-fit:cover;
  border-radius: var( --image_radius);
}

.image-text-slider__content{
  padding: 1rem;
}

.image-text-slider__subtitle{
  display:block;
  font-size: clamp({{ subtitle_mobilesize }}px,1vw,{{ subtitle_desktopsize }}px);
  line-height: 1;
  color: {{subtitle_color}};
  text-transform: capitalize;
  letter-spacing: normal;
  margin: 0;
  font-weight: 500;
}

.image-text-slider__title{
  margin:0;
  font-size: clamp({{ title_mobilesize }}px,2.5vw,{{ title_desktopsize }}px);
  line-height:1;
  font-weight:700;
  color: {{title_color}};
}

.image-text-slider__description{
  font-size:clamp(0.9rem,1.2vw,1.05rem);
  line-height:1.7;
  color:#444;
}

.image-text-slider__description p{
  margin:0;
}


</style>

{% schema %}
{
  "name": "Image Text Slider",
  "class": "swiper-slide",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image Link"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Featured Collection"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "subtitle_mobilesize",
      "label": "Subtitle Mobile Size",
      "max": 34,
      "min": 16,
      "default": 24,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subtitle_desktopsize",
      "label": "Subtitle Desktop Size",
      "max": 40,
      "min": 18,
      "default": 26,
      "step": 1,
      "unit": "px"
    },
      {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Image Text Slider"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "title_mobilesize",
      "label": "Title Mobile Size",
      "max": 48,
      "min": 20,
      "default": 44,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_desktopsize",
      "label": "Title Desktop Size",
      "max": 70,
      "min": 40,
      "default": 70,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add a short description for this slide.</p>"
    }
    
  ],
  "presets": [
    {
      "name": "Image Text Slider"
    }
  ]
}
{% endschema %}