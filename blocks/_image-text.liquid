
<div class="image-text-slider">
  {% if block.settings.image_link != blank %}
    <a href="{{ block.settings.image_link }}" class="image-text-slider__image-link">
  {% endif %}

    {% if block.settings.image != blank %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.title | escape }}"
        loading="lazy"
        class="image-text-slider__image"
      >
      {% else %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    

  {% if block.settings.image_link != blank %}
    </a>
  {% endif %}

  <!-- OVERLAY -->
    <div class="image-overlay">&nbsp</div>
  

  <div class="image-text-slider__content">
    {% if block.settings.subtitle != blank %}
      <span class="image-text-slider__subtitle">
        {{ block.settings.subtitle }}
      </span>
    {% endif %}

    {% if block.settings.title != blank %}
      <h3 class="image-text-slider__title">
        {{ block.settings.title }}
      </h3>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="image-text-slider__description">
        {{ block.settings.description }}
      </div>
    {% endif %}
  </div>
</div>

<style>
.image-text-slider{
  display:flex;
  flex-direction:column;
  width:100%;
  height:100%;
  overflow:hidden;
  position: relative;
}

.image-text-slider__image-link{
  display:block;
  line-height:0;
}

.image-text-slider__image{
  width:100%;
  /* max-width: 300px; */
  display:block;
  object-fit:cover;
  border-radius:{{ block.settings.image_radius }}px;
}

.image-text-slider__content{
  padding: 1rem;
}

.image-text-slider__subtitle{
  display:block;
  margin-bottom:0.5rem;
  font-size:clamp(0.75rem,1vw,0.95rem);
  line-height:1.4;
  color:#666;
  text-transform:uppercase;
  letter-spacing:0.08em;
}

.image-text-slider__title{
  margin:0 0 0.75rem;
  font-size:clamp(1.25rem,2.5vw,2rem);
  line-height:1.2;
  font-weight:700;
  color: rgb(var(--color-foreground));
}

.image-text-slider__description{
  font-size:clamp(0.9rem,1.2vw,1.05rem);
  line-height:1.7;
  color:#444;
}

.image-text-slider__description p{
  margin:0;
}

@media screen and (max-width:749px){
  .image-text-slider__content{
    padding:0.875rem 0;
  }
}
</style>

{% schema %}
{
  "name": "Image Text Slider",
  "class": "swiper-slide",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image Link"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Image Text Slider"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add a short description for this slide.</p>"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image Text Slider"
    }
  ]
}
{% endschema %}