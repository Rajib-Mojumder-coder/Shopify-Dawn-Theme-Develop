
{% liquid
   assign enable_img_position = block.settings.enable_img_position
  assign advisor_img_y_offset = block.settings.advisor_img_y_offset
  assign advisor_card_bg = block.settings.advisor_card_bg
  assign card_bg_color = block.settings.card_bg_color
  assign transparant_img_bg = block.settings.transparant_img_bg
  assign transparant_img_bg_color = block.settings.transparant_img_bg_color
%}

<div class="advisor-card advisor-card{{ block.id }}" {{ block.shopify_attributes }}>

    <div class="advisor-card-container">

      <div class="image-icon-wrapper">

         {% if block.settings.advisor_image != blank %}
          <div class="advisor-image">
           
              {{
                block.settings.advisor_image
                | image_url: width: 2000
                | image_tag:
                loading: 'lazy',
                class: 'advisor-img'
              }}
          </div>
        
        
        {% endif %}

        {% if block.settings.advisor_icon != blank %}
          <div class="advisor-icon">
              {{
                block.settings.advisor_icon
                | image_url: width: 150
                | image_tag:
                loading: 'lazy'
              }}
          </div>
        {% endif %}

    </div>

    <div class="button-area">
     
        {% render 'custom-global-button',
          button_text: block.settings.button_text,
          button_link: block.settings.button_link
        %}
       
    </div>

    </div>

</div>

<style>
.advisor-card{{ block.id }}{
    width:100%;
    height: 100%;
    padding-top: 30px;
}
.advisor-card{{ block.id }} > .advisor-card-container{
    width:100%;
    height: 100%;
    max-width:100%;
    {% if advisor_card_bg == true%}
    background: {{card_bg_color | color_modify: 'alpha', 0.3 }};
    {% endif %}
    backdrop-filter: blur(10px);
   -webkit-backdrop-filter: blur(10px);
    border-radius:24px;
    display:flex;
    flex-direction:column;
}

.advisor-card{{ block.id }} .image-icon-wrapper{
  position: relative;
  width:100%;
   aspect-ratio: 10 / 5.2;
}
.advisor-card{{ block.id }} .advisor-image{
  width:100%;
  height: 100%;
  position: relative;
  display: inline-block;
  z-index: 6;
}

.advisor-card{{ block.id }} .advisor-img{
  width:100%;
  height:100%;
  object-fit:fill;
  object-position:top;
  z-index:6;

  {% if enable_img_position %}
    position:absolute;
    inset: {{ advisor_img_y_offset }}px 0 0 0;
  {% endif %}

  border-bottom-right-radius:200px;
}
.advisor-card{{ block.id }} .advisor-image::before{
  content: "";
  position: absolute;
  inset: 0;
  width: 100%;
  {% if enable_img_position %}
    height:calc(100% - {{ advisor_img_y_offset | times: -1 }}px);
  {% else %}
    height:100%;
  {% endif %}

  {% if transparant_img_bg %}
    background: {{ transparant_img_bg_color }};
  {% endif %}

  border-radius: 24px 24px 200px 0;
  
  z-index: -1;
}

.advisor-card{{ block.id }} .advisor-icon{
  max-width: 49px;
  position: absolute;
  left: 50%;
  top: 100%;
  transform: translate(-50%, -80%);
  z-index: 8;
}
.advisor-card{{ block.id }} .advisor-icon img{
  width:100%;
  height: 100%;
  object-fit: cover;
}
.advisor-card{{ block.id }} .button-area{
  width: 100%;
  height: 25%;
  display:flex;
  justify-content:center;
  padding: 20px;
}

@media(max-width: 1100px){
 .advisor-card{{ block.id }} .image-icon-wrapper{
  aspect-ratio: 10 / 5.5;
}
.advisor-card{{ block.id }} .advisor-img{
  border-bottom-right-radius: 190px;
}
.advisor-card{{ block.id }} .advisor-image::before{
  border-radius: 24px 24px 190px 0;
} 
}

@media(min-width: 768px) and (max-width: 1023px){
.advisor-card{{ block.id }} .image-icon-wrapper{
  aspect-ratio: 10 / 6;
}
.advisor-card{{ block.id }} .advisor-img{
  object-fit: cover;
}
.advisor-card{{ block.id }} .advisor-img{
  border-bottom-right-radius: 140px;
}
.advisor-card{{ block.id }} .advisor-image::before{
  border-radius: 24px 24px 140px 0;
}
}

@media(max-width: 450px){
.advisor-card{{ block.id }} .advisor-img{
  border-bottom-right-radius: 140px;
}
.advisor-card{{ block.id }} .advisor-image::before{
  border-radius: 24px 24px 140px 0;
}
.advisor-card{{ block.id }} .button-area{
  padding: 14px;
}
}


</style>

{% schema %}
{
  "name": "Advisor Card",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "advisor_image",
      "label": "Advisor Image"
    },
    {
      "type": "checkbox",
      "id": "enable_img_position",
      "label": "Enable Custom Image Position",
      "default": false
    },
    {
      "type": "range",
      "id": "advisor_img_y_offset",
      "label": "Image Position Y",
      "min": -40,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": -20,
      "visible_if": "{{ block.settings.enable_img_position }}"
    },
    {
      "type": "checkbox",
      "id": "advisor_card_bg",
      "label": "Card Custom Background",
      "default": true
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background Color",
      "default": "#071540",
      "visible_if": "{{ block.settings.advisor_card_bg }}"
    },
    {
      "type": "checkbox",
      "id": "transparant_img_bg",
      "label": "Image Background",
      "default": true
    },
    {
      "type": "color",
      "id": "transparant_img_bg_color",
      "label": "Background Color",
      "default": "#06123D",
      "visible_if": "{{ block.settings.transparant_img_bg }}"
    },
    {
      "type": "image_picker",
      "id": "advisor_icon",
      "label": "Center Icon"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "ADVIESGESPREK"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Advisor Card"
    }
  ]
}
{% endschema %}
{%  comment  %} 
claude:
<style>
.advisor_img--{{ block.id }} {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: {{ block.settings.bg_color }};
    border-radius: 20px;
    position: relative;
    box-sizing: border-box;
    margin: 2rem;
}

.advisor_img--{{ block.id }}::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: calc(75% - 20px);
    border-radius: 20px 20px 200px 0;
    background: #000;
    z-index: 2;
}


.advisor_img--{{ block.id }} .transparent-image {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 75%;
    object-fit: cover;
    border-bottom-right-radius: 200px;
    transform: translateY({{ block.settings.image_vertical_offset }}px);
    z-index: 4;
}

.advisor_img--{{ block.id }} .button-container {
    margin-top: {{ block.settings.content_gap }}px;
    text-align: center;
    padding: 20px;
    position: relative;
    z-index: 5;
    height: 25%;
}

.advisor_img--{{ block.id }} .button-container a {
    display: inline-block;
    color: {{ block.settings.button_text_color }};
    background: {{ block.settings.bg_color }};
    padding: 12px 24px;
    border-radius: 20px;
    text-decoration: none;
    transition: opacity .3s;
}

.advisor_img--{{ block.id }} .button-container a:hover {
    opacity: .85;
}

.advisor_img--{{ block.id }} .icon-container {
    width: 100px;
    aspect-ratio: 1;
    margin: 20px auto;
    position: relative;
    z-index: 6;
}

.advisor_img--{{ block.id }} .icon-container img {
    width: 100%;
    height: auto;
}
</style>

<div class="advisor_img--{{ block.id }}">

    {% if block.settings.image != blank %}
        {{
            block.settings.image
            | image_url: width: 1200
            | image_tag:
            class: 'transparent-image',
            alt: block.settings.image.alt
        }}
    {% endif %}

    <div class="button-container">

        {% if block.settings.icon != blank %}
            <div class="icon-container">
                {{
                    block.settings.icon
                    | image_url: width: 200
                    | image_tag:
                    class: 'icon',
                    alt: 'Icon'
                }}
            </div>
        {% endif %}

        <a
            href="{{ block.settings.target_url }}"
            class="custom-button"
            aria-label="{{ block.settings.aria_label }}"
        >
            {{ block.settings.button_label }}
        </a>

        

    </div>

</div>

