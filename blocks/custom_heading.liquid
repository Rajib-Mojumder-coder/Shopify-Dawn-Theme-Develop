            "max": 46,
            "step": 1,
            "unit": "px",
            "default": 25,
            "visible_if": "{{ block.settings.subtitle_typography }}"
        },
        {
            "type": "range",
            "id": "subtitle_line_height",
            "label": "Subtitle Line Height",
            "min": 0.8,
            "max": 2,
            "step": 0.1,
            "default": 1,
            "visible_if": "{{ block.settings.subtitle_typography }}"
        },
        {
            "type": "range",
            "id": "subtitle_letter_spacing",
            "label": "Subtitle Letter Spacing",
            "min": -5,
            "max": 20,
            "step": 1,
            "unit": "px",
            "default": 0,
            "visible_if": "{{ block.settings.subtitle_typography }}"
        },
        {
            "type": "select",
            "id": "subtitle_transform",
            "label": "Subtitle Text Transform",
            "options": [
                { "value": "none", "label": "None" },
                { "value": "uppercase", "label": "UPPERCASE" },
                { "value": "lowercase", "label": "lowercase" },
                { "value": "capitalize", "label": "Capitalize" }
            ],
            "default": "none",
            "visible_if": "{{ block.settings.subtitle_typography }}"
        },
