            "default": false
        },
        {
            "type": "color",
            "id": "heading_color",
            "label": "Heading Color",
            "default": "#000000",
            "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "mobile_min_fontsize",
            "label": "Mobile Font Size",
            "min": 24,
            "max": 80,
            "step": 1,
            "unit": "px",
            "default": 32,
            "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "desktop_max_fontsize",
            "label": "Desktop Font Size",
            "min": 30,
            "max": 130,
            "step": 1,
            "unit": "px",
            "default": 80,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "select",
            "id": "font_weight",
            "label": "Font Weight",
            "options": [
                { "value": "300", "label": "Light" },
                { "value": "400", "label": "Regular" },
                { "value": "500", "label": "Medium" },
                { "value": "600", "label": "Semi Bold" },
                { "value": "700", "label": "Bold" },
                { "value": "800", "label": "Extra Bold" },
                { "value": "900", "label": "Black" }
            ],
            "default": "700",
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "line_height",
            "label": "Line Height",
            "min": 0.8,
            "max": 2,
            "step": 0.1,
            "default": 1,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
            "type": "range",
            "id": "letter_spacing",
            "label": "Letter Spacing",
            "min": -5,
            "max": 20,
            "step": 1,
            "unit": "px",
            "default": 0,
             "visible_if": "{{ block.settings.typography }}"
        },
        {
