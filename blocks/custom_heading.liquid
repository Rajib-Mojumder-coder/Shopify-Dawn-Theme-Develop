            "options": [
                { "value": "h1", "label": "H1" },
                { "value": "h2", "label": "H2" },
                { "value": "h3", "label": "H3" },
                { "value": "h4", "label": "H4" },
                { "value": "h5", "label": "H5" },
                { "value": "h6", "label": "H6" }
            ],
            "default": "h2"
        },
        {
            "type": "inline_richtext",
            "id": "custom_heading",
            "label": "Heading",
            "default": "Your heading here"
        },
        {
