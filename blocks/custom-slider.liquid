    },
    {
      "type": "checkbox",
      "id": "free_mode",
      "label": "Free Mode",
      "default": false,
      "visible_if": "{{ block.settings.slider_settings }}",
      "info": "Behaving like Smooth Scrolling in Swipe"
    },
    {
      "type": "checkbox",
      "id": "touch_swipe", 
      "label": "Touch Swipe",
      "default": true,
      "visible_if": "{{ block.settings.slider_settings }}",
      "info": "Touch devices allowed finger swipe"
    },
    {
      "type": "checkbox",
      "id": "keyboard",
      "label": "Kayborar",
      "default": true,
      "visible_if": "{{ block.settings.slider_settings }}",
      "info": "Keyborad Next & Prev Button for slider change"
    },
    {
      "type": "checkbox",
      "id": "mousewheel",
      "label" : "Mousewheel",
      "default": false,
      "visible_if": "{{ block.settings.slider_settings }}",
      "info": "Mousewheel Allowed for slider change"
    },
    {
      "type": "checkbox",
      "id": "grab_cursor",
      "label": "Grab Cursor",
      "default": true,
      "visible_if": "{{ block.settings.slider_settings }}"
    },
    {
      "type": "checkbox",
      "id": "auto_height",
      "label": "Auto Height",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Desktop Navigation",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Navigation Icon Type",
      "default": "theme_arrow",
      "options": [
        {
          "value": "theme_arrow",
          "label": "Theme Arrow"
        },
        {
          "value": "image",
          "label": "Custom Image"
        },
        {
          "value": "svg_code",
          "label": "Custom SVG"
        }
      ],
      "visible_if": "{{ block.settings.show_navigation }}"
    },
    {
      "type": "range",
      "id": "stroke_width",
      "label": "Arrow Stroke Width",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2,
      "visible_if": "{{ block.settings.show_navigation and block.settings.icon_type == 'theme_arrow' }}"
    },
    {
      "type": "image_picker",
      "id": "prev_icon",
      "label": "Previous Icon",
      "visible_if": "{{ block.settings.show_navigation and block.settings.icon_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "next_icon",
      "label": "Next Icon",
      "visible_if": "{{ block.settings.show_navigation and  block.settings.icon_type == 'image' }}"
    },
    {
      "type": "textarea",
      "id": "prev_svg",
      "label": "Previous SVG",
      "visible_if": "{{ block.settings.show_navigation and  block.settings.icon_type == 'svg_code' }}"
    },
    {
      "type": "textarea",
      "id": "next_svg",
      "label": "Next SVG",
      "visible_if": "{{ block.settings.show_navigation and  block.settings.icon_type == 'svg_code' }}"
    },
    {
      "type": "header",
      "content": "Navigation Style",
      "visible_if": "{{ block.settings.show_navigation }}"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 12,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.show_navigation }}"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000",
      "visible_if": "{{ block.settings.show_navigation }}"
    },
    {
      "type": "color",
      "id": "hover_icon_color",
      "label": "Hover Icon Color",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.show_navigation }}"
    },
    {
      "type": "color",
      "id": "bg_color",
