      "max": 9000,
      "step": 100,
      "default": 5000,
      "unit": "ms",
      "visible_if": "{{ block.settings.slider_settings and block.settings.autoplay}}"
    },
    {
      "type": "checkbox",
      "id": "disable_on_interaction",
      "label": "Keep autoplay after interaction",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
