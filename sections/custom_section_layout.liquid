
{{ 'custom_section_layout.css' | asset_url | stylesheet_tag }}

{% liquid
  assign layout_type    = section.settings.layout_type
  assign layout_max_width    = section.settings.layout_max_width
  
  assign color_scheme        = section.settings.color_scheme
  assign background_media        = section.settings.background_media
  assign background_image        = section.settings.background_image
  assign background_image_fit        = section.settings.background_image_fit
  assign background_object_position        = section.settings.background_object_position
  assign background_overlay        = section.settings.background_overlay

  assign padding_top         = section.settings.padding_top
  assign padding_bottom      = section.settings.padding_bottom

  assign desktop_layout      = section.settings.desktop_layout
  assign desktop_direction   = section.settings.desktop_direction
  assign desktop_wrap        = section.settings.desktop_wrap
  assign desktop_justify  = section.settings.desktop_justify
  assign desktop_align     = section.settings.desktop_align
  assign desktop_columns          = section.settings.desktop_columns
  assign desktop_gap              = section.settings.desktop_gap

  assign mobile_layout     = section.settings.mobile_layout
  assign mobile_direction  = section.settings.mobile_direction
  assign mobile_wrap       = section.settings.mobile_wrap
  assign mobile_justify    = section.settings.mobile_justify
  assign mobile_align      = section.settings.mobile_align
  assign mobile_columns    = section.settings.mobile_columns
  assign mobile_gap        = section.settings.mobile_gap
%}
<style>
  {%- capture section_height -%}

  {% case section.settings.section_height_mode %}

    {% when 'preset' %}

      {% case section.settings.preset_height %}
        {% when 'small' %}
          clamp(320px, 40vh, 500px)

        {% when 'medium' %}
          clamp(450px, 60vh, 800px)

        {% when 'large' %}
          clamp(600px, 80vh, 1100px)

        {% when 'fullscreen' %}
          100vh

        {% else %}
          auto
      {% endcase %}

    {% when 'custom' %}
      clamp(
        {{ section.settings.custom_min_height }}px,
        {{ section.settings.custom_viewport_height }}vh,
        {{ section.settings.custom_max_height }}px
      )

    {% else %}
      auto
  {% endcase %}

{%- endcapture -%}

/* ====BACKGROUND======= */
.csl-{{ section.id }}.custom-section-main{
position: relative;
overflow: hidden;
isolation: isolate;
background: rgb(var(--color-background)) !important;
padding-block:
    var(--padding-top, 0)
    var(--padding-bottom, 0);

  min-height: var(--section-min-height, auto);
}
.csl-{{ section.id }} .csl-bg{
  position: absolute;
  inset: 0;
  z-index: -3;
}

.csl-{{ section.id }} .csl-bg-image,
.csl-{{ section.id }} .csl-bg-video{
  width: 100%;
  height: 100%;
  object-fit: {{ background_image_fit }};
  object-position: {{ background_object_position }};
}
  /* =========OVERLAY======= */

.csl-{{ section.id }} .csl-overlay{
  position: absolute;
  inset: 0;
  z-index: -2;
  pointer-events: none;
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  mix-blend-mode: {{ section.settings.overlay_blend }};
   backdrop-filter: blur({{ section.settings.overlay_blur }}px);
  -webkit-backdrop-filter: blur({{ section.settings.overlay_blur }}px);

  {% if section.settings.overlay_style == 'solid' %}
    background: {{ section.settings.overlay_color }};
  {% else %}
    background: {{ section.settings.overlay_gradient }};
  {% endif %}
}

/* =======INNER====== */

.csl-{{ section.id }} .csl-inner{
  position: relative;
  z-index: 2;
  height: 100%;
}
  /* ===== CONTAINER WIDTH SYSTEM ========= */
 .csl-{{ section.id }} .csl-layout-custom{
    max-width: {{ layout_max_width }};
  }

  .csl-{{ section.id }} .csl-layout-full{
    max-width: 100%;
  }

    /* ======= Surface/ Border============ layout_solid_bg*/
    
  .csl-{{ section.id }} .csl-surface {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: transparent;
    min-height: var(--cbs-min-height);
    padding: var(--layout-padding-top) var(--layout-padding-right) var(--layout-padding-bottom) var(--layout-padding-left);
    border-radius: var(--cbs-border-radius);
    transition:
      border-color 0.3s ease,
      transform 0.3s ease;
  }
{%  capture surface_styles %} 
  --cbs-min-height: {{ section.settings.surface_min_height }}px;
  --layout-solid-bg: {{ section.settings.layout_solid_bg }};
  --layout-gradient-bg: {{ section.settings.layout_gradient_bg }};
  --layout-padding-top: {{ section.settings.layout_padding_top }}px;
  --layout-padding-bottom: {{ section.settings.layout_padding_bottom }}px;
  --layout-padding-left: {{ section.settings.layout_padding_left }}px;
  --layout-padding-right: {{ section.settings.layout_padding_right }}px;
  --cbs-border-radius: {{ section.settings.border_radius }}px;
  --cbs-border-width: {{ section.settings.border_width }}px;
  --cbs-border-style: {{ section.settings.border_style }};
  --cbs-border-color: {{ section.settings.border_color }};
  --cbs-border-opacity: {{ section.settings.border_opacity | divided_by: 100.0 }};
  --cbs-border-hover-color: {{ section.settings.border_hover_color }};
{% endcapture %}
  /* BACKGROUND */
.csl-{{ section.id }} .csl-surface.csl-layout-bg-solid {
  background: var(--layout-solid-bg);
}

.csl-{{ section.id }} .csl-surface.csl-layout-bg-gradient {
  background: var(--layout-gradient-bg);
}

  .csl-{{ section.id }} .csl-surface.csl-border-enabled {
    border-width: var(--cbs-border-width);
    border-style: var(--cbs-border-style);
    border-color: color-mix(in srgb, var(--cbs-border-color) calc(var(--cbs-border-opacity) * 100%),transparent);
  }
  .csl-{{ section.id }} .csl-surface.csl-border-hover-enabled:hover {
  border-color: color-mix(in srgb, var(--cbs-border-hover-color) calc(var(--cbs-border-opacity) * 100%), transparent);
}
    /* ======= BLOCKS BASE============ */

  .csl-{{ section.id }} .csl-blocks{
    width: 100%;
  }

   /* ======DESKTOP========== */

  @media screen and (min-width: 768px){
    .csl-{{ section.id }} .csl-blocks{
      gap: var(--desktop-gap);
      {% if desktop_layout == 'flex' %}
      display: flex;
      flex-direction: {{ desktop_direction }};
      flex-wrap: {{ desktop_wrap }};
      justify-content: {{ desktop_justify }};
      align-items: {{ desktop_align }};
       {% else %}
      display: grid;
      grid-template-columns: repeat(var(--desktop-columns), minmax(0,1fr));
        justify-content: {{ desktop_justify }};
        align-items: {{ desktop_align }};
      {% endif %}
    }
  }

  /* =======MOBILE========*/

  @media screen and (max-width: 767px){

    .csl-{{ section.id }} .csl-blocks{
      gap: var(--mobile-gap);
      {% if mobile_layout == 'flex' %}
        display: flex;
        flex-direction:  {{ mobile_direction }};
        flex-wrap:       {{ mobile_wrap }};
        justify-content:    {{ mobile_justify }};
        align-items:  {{ mobile_align }};
      {% else %}
        display: grid;
        grid-template-columns: repeat( var(--mobile-columns), minmax(0,1fr));
        justify-content: {{ mobile_justify }};
        align-items: {{ mobile_align }};
      {% endif %}
    }
  }
</style>

<div class="custom-section-main csl-{{ section.id }} color-{{ color_scheme }} gradient" style="--section-min-height: {{ section_height | strip }}; --padding-top: {{ padding_top }}px;--padding-bottom: {{ padding_bottom }}px;">
  <!-- BACKGROUND --> 
   <div class="csl-bg">
      {% if background_media == 'image' and background_image != blank %}
      <img src="{{ background_image | image_url: width: 3500 }}" alt="" class="cbs-bg-image">
    {% elsif background_media == 'video' and section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'cbs-bg-video'
      }}
    {% endif %}
   </div>

   <!-- OVERLAY -->
  {% if background_overlay %}
    <div class="csl-overlay">&nbsp</div>
  {% endif %}

   <!-- CONTENT -->
  <div class="csl-inner">
    <div class="page-width cbs-layout-{{ layout_type }}">
       <!-- SURFACE -->
      <div class="csl-surface csl-layout-bg-{{ section.settings.layout_background }}
      {% if section.settings.enable_border %}cbs-border-enabled{% endif %}
        {% if section.settings.border_hover_color != blank %}cbs-border-hover-enabled{% endif %}"
        style="{{surface_styles |  strip}}">
        <!-- BLOCKS -->
        <div class="csl-blocks">
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  </div>
</div>

