1) section code:
{%liquid
  assign color_scheme = section.settings.color_scheme
  assign header_logo_width = section.settings.header_logo_width
  assign header_logo_height = section.settings.header_logo_height
%}
<header class="custom_header color-{{ color_scheme }} gradient"
 style="--header-logo-width: {{ header_logo_width }}px; --header-logo-height: {{ header_logo_height }}px;"
>
    <div class="page-width custom_header_container">
        <div class="custom_header_inner">
                <div class="custom_header_branding">
                    {% render 'custom_header_logo' %}
                </div>

                <div class="custom_header_navigation">
                    {% render '_custom_header_navigation' %}
                </div>

                <div class="custom_header_actions">
                    {% render 'custom_header_actions' %}
                </div>

                <div class="custom_header_mobile_actions">
                    {% render 'custom_header_mobile_actions' %}
                </div>
        </div>
    </div>
</header>

<style>
    .custom_header{
    position: relative;
    z-index: 100;
}
.custom_header_container{
    width: 100%;
    height: 100%;
    max-width: 1240px;
}
.custom_header_inner{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:40px;
    min-height:90px;
    position:relative;
}
.custom_header_branding{
    flex:0 0 auto;
    width:var(--header-logo-width);
    height:var(--header-logo-height);
}

.custom_header_navigation{
    flex:1 1 auto;
    min-width:0;
    position:relative;
}

.custom_header_actions{
    flex:0 0 auto;
}

.custom_header_mobile_actions{
    display:none;
}

</style>

{%  schema  %} 
{
    "name": "Custom Header",
    "class": "custom_header",
    "disabled_on": {
        "groups": ["footer", "aside"]
    },
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color Scheme",
            "default": "scheme-5"
        },
        {
            "type": "link_list",
            "id": "custom_menu",
            "label": "Header Menu"
        },
        {
            "type": "image_picker",
            "id": "header_logo",
            "label": "Header Logo"
        },
        {
        "type": "range",
        "id": "header_logo_width",
        "label": "Logo Width",
        "min": 80,
        "max": 180,
        "step": 1,
        "default": 107,
        "unit": "px"
        },
        {
        "type": "range",
        "id": "header_logo_height",
        "label": "Logo Height",
        "min": 30,
        "max": 130,
        "step": 1,
        "default": 65,
        "unit": "px"
        }
        
    ],
    "blocks": [
        {
            "type": "custom_mega_menu",
            "name": "Mega Menu",
            "settings": [
                {
                "type": "text",
                "id": "menu_handle",
                "label": "Menu Handle"
                },
                {
                "type": "text",
                "id": "heading",
                "label": "Heading"
                },
                {
                "type": "image_picker",
                "id": "promo_image",
                "label": "Promotion Image"
                },
                {
                "type": "text",
                "id": "promo_title",
                "label": "Promotion Title"
                },
                {
                "type": "text",
                "id": "button_text",
                "label": "Button Text"
                },
                {
                "type": "url",
                "id": "button_link",
                "label": "Button Link"
                },
                {
                "type": "color",
                "id": "button_color",
                "label": "Button Color",
                "default": "#58B7A5"
                },
                {
                "type": "text",
                "id": "featured_collection_handle",
                "label": "Featured Collection Handle"
                }
            ]
        },
        {
        "type": "mega_menu_slide",
        "name": "Mega Menu Slide",
        "settings": [
            {
            "type": "text",
            "id": "parent_handle",
            "label": "Parent Mega Menu Handle",
            "info": "Must match the Mega Menu Handle."
            },
            {
            "type": "checkbox",
            "id": "enable_slide",
            "label": "Enable Slide",
            "default": true
            },
            {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
            },
            {
            "type": "text",
            "id": "button_text",
            "label": "Button Text",
            "default": "Learn More"
            },
            {
            "type": "url",
            "id": "button_link",
            "label": "Button Link"
            },
            {
            "type": "color",
            "id": "button_bg",
            "label": "Button Background",
            "default": "#58B7A5"
            },
            {
            "type": "color",
            "id": "button_text_color",
            "label": "Button Text",
            "default": "#ffffff"
            }
        ]
        }
    ]
}
{% endschema %}


2/ snippets:
{% liquid
    assign main_menu = section.settings.custom_menu
%}

<ul class="custom-main-menu">
    {% for parent in main_menu.links %}
          {% liquid assign mega_block = blank
            assign parent_title = parent.title | downcase | strip
            for block in section.blocks
            if block.type == 'custom_mega_menu'
                assign block_menu = block.settings.menu_handle | downcase | strip
                if block_menu == parent_title
                assign mega_block = block
                break
                endif
            endif
            endfor   %}

        <li class="custom-main-menu__item{% if mega_block != blank %} has-mega{% endif %}">

            <a href="{{ parent.url }}" class="custom-main-menu__link {% if parent.active %}is-active{% endif %}">
                {{ parent.title }}
            </a>

            {% if mega_block != blank %}  
                {% render '__custom_mega_menu', block: mega_block, parent: parent %}
            {% endif %}

        </li>

    {% endfor %}

</ul>

<style>
   .custom-main-menu{
    position:static;
    display:flex;
    align-items:center;
    justify-content:flex-start;
    gap:42px;
    margin:0;
    padding:0;
    list-style:none;
}

.custom-main-menu__item{
    flex:0 0 auto;
}

.custom-main-menu__link{
    display:flex;
    align-items:center;
    height:90px;
    color:#fff;
    text-decoration:none;
    font-weight:500;
    transition:.25s;
}

.custom-main-menu__link:hover{
    color:#58B7A5;
}

.custom-main-menu__link.is-active{
    color:#58B7A5;
}
</style>


3. mega menu snippets:
<div class="custom-mega-menu">
{% comment %} <p>Parent: {{ parent.title }}</p> {% endcomment %}
    <div class="custom-mega-menu__wrapper">

        <div class="custom-mega-menu__left">

            {% if block.settings.heading != blank %}

                <h3 class="custom-mega-menu__heading">

                    {{ block.settings.heading }}

                </h3>

            {% endif %}
            
            {% render 'custom_mega_menu_items',
                parent: parent %}

        </div>

        <div class="custom-mega-menu__right">

            {% render '___custom_mega_menu_slider',
                mega_block: block,
                section: section
            %}

        </div>

    </div>

</div>

<style>
.custom-mega-menu{
    position:absolute;
    left:0;
    top:90px;
    width: 100%;
    max-width:1240px;
    opacity: 1;
    visibility: visible;
    z-index:100;
}

.custom-main-menu__item:hover > .custom-mega-menu{
    display:block;
    opacity: 1;
    visibility: visible;
}

.custom-mega-menu__wrapper{
    display:grid;
    grid-template-columns: 2fr 1fr;
    gap:40px;
    padding: 50px 35px;
    border-radius:0 0 32px 32px;
    background:#081C4A;
}

.custom-mega-menu__left{
    width:100%;
}

.custom-mega-menu__heading{
    color:#fff;
    font-size:30px;
    margin-bottom:40px;
}

/*Right Phase*/
.custom-mega-menu__right{
    display:flex;
    justify-content:center;
    align-items:center;
}
</style>

4. snippets mega menu items: 
<div class="mega-menu-items">

{% for child in parent.links %}

    {% assign collection = child.object %}

    <a href="{{ child.url }}" class="mega-menu-item">

        <div class="mega-menu-item__icon">

            {% if collection and collection.metafields.custom.menu_icon %}

                {{
                    collection.metafields.custom.menu_icon
                    | image_url: width: 48
                    | image_tag
                }}

            {% endif %}

        </div>

        <div class="mega-menu-item__content">
            <span class="mega-menu-item__title">{{ child.title }}</span>
            <span class="mega-menu-item__arrow">  <img src="{{ 'forward-slash-icon.svg' | asset_url }}" alt=""> </span>
        </div>
    </a>

{% endfor %}

</div>



<style>
    .mega-menu-items{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:8px 10px;
}

.mega-menu-item{
    display:flex;
    align-items:center;
    gap:16px;
    text-decoration:none;
    color:#fff;

    width:fit-content;
    min-width: 190px;
    padding: 0 12px 0 0;

    border-radius:999px;
    background:transparent;
    transition:all .3s ease;
}
.mega-menu-item:hover
{
    background:#020922;
}
.mega-menu-item:hover
.mega-menu-item__icon
{
    background:#52B099;
}

.mega-menu-item__icon{
    width: 46px;
    height: 46px;
    max-width: 100%;
    max-height: 100%;
    border-radius:50%;
    border:1px solid rgba(255,255,255,.25);
    display:flex;
    justify-content:center;
    align-items:center;
    flex-shrink:0;
    padding: 7px;
    transition:all .3s ease;
}

.mega-menu-item__icon > img{
    width:100%;
    height:100%;
    object-fit: scale-down;
    max-width: 30px;
}
.mega-menu-item__content{
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
}
.mega-menu-item__title{
    display:block;
}

 .mega-menu-item__arrow{
    width:18px;
    height:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
}

.mega-menu-item__arrow img{
    width:100%;
    transform:translateX(-10px);
    opacity:0;
    transition:all .3s ease;
}

.mega-menu-item:hover .mega-menu-item__arrow img{
    transform:translateX(0);
    opacity:1;
}
</style>
{% endcomment %}