{% comment %} 
 {% liquid
  assign slides = section.blocks | where: "type", "slide"
%}

<section class="custom-hero-{{ section.id }}">

  <style>
    .custom-hero-{{ section.id }} {
      --hero-blue: {{ section.settings.color_blue }};
      --hero-green: {{ section.settings.color_green }};
      --accent: {{ section.settings.color_accent }};

      /* 🔥 BIG BLUE, SMALL GREEN */
      --split: clamp(450px, 65vh, 780px);

      min-height: clamp(700px, 95vh, 950px);

      background: linear-gradient(
        to bottom,
        var(--hero-blue) 0,
        var(--hero-blue) var(--split),
        var(--hero-green) var(--split),
        var(--hero-green) 100%
      );

      position: relative;
      overflow: hidden;
    }

    .hero-inner {
      max-width: 1728px;
      margin: 0 auto;
      position: relative;
    }

    /* TITLE */
    .hero-top {
      text-align: center;
      padding-top: clamp(40px, 8vh, 90px);
      position: relative;
      z-index: 3;
    }

    /* 🔥 SEARCH EXACT SPLIT */
    .hero-search-anchor {
      position: absolute;
      top: var(--split);
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      max-width: 1246px;
      z-index: 5;
    }

    /* SWIPER */
    .hero-swiper {
      max-width: 1485px;
      margin: calc(var(--split) * 0.15) auto 0;
      position: relative;
    }

    .hero-swiper .swiper-slide {
      aspect-ratio: 1485 / 900;
      overflow: hidden;
    }

    .hero-swiper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* BUTTON */
    .hero-btn {
      display: flex;
      justify-content: center;
      margin-top: 20px;
    }

    .hero-btn a {
      width: 225px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent);
      color: #fff;
      text-decoration: none;
    }

    /* MOBILE */
    @media(max-width: 768px){
      .custom-hero-{{ section.id }} {
        --split: 55vh;
      }
    }

  </style>

  <div class="hero-inner">

    <!-- TITLE -->
    <div class="hero-top">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.description }}</p>
    </div>

    <!-- 🔥 SEARCH -->
    <div class="hero-search-anchor">
      {% render 'hero_search_bar',
        search_placeholder: section.settings.search_placeholder,
        search_button_text: section.settings.search_button_text
      %}
    </div>

    <!-- 🔥 SWIPER SLIDER -->
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {% for block in slides %}
          <div class="swiper-slide">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 1500 | image_tag }}
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- BUTTON -->
    {% if section.settings.button_text != blank %}
    <div class="hero-btn">
      <a href="{{ section.settings.button_link }}">
        {{ section.settings.button_text }}
      </a>
    </div>
    {% endif %}

  </div>

  <!-- 🔥 SWIPER INIT -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      new Swiper(".custom-hero-{{ section.id }} .hero-swiper", {
        loop: true,
        effect: "fade",
        autoplay: {
          delay: {{ section.settings.autoplay_speed }},
          disableOnInteraction: false
        }
      });
    });
  </script>

</section>

