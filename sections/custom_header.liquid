{%liquid
  assign color_scheme = section.settings.color_scheme
  assign header_logo_width = section.settings.header_logo_width
  assign header_logo_height = section.settings.header_logo_height
%}
<header class="custom_header color-{{ color_scheme }} gradient"
 style="--header-logo-width: {{ header_logo_width }}px; --header-logo-height: {{ header_logo_height }}px;"
>
    <div class="page-width custom_header_container">
        <div class="custom_header_wrapper">
                <div class="custom_header_branding">
                    {% render 'custom_header_logo' %}
                </div>

                <div class="custom_header_navigation">
                    {% render 'custom_header_navigation' %}
                </div>

                <div class="custom_header_actions">
                    {% render 'custom_header_actions' %}
                </div>

                <div class="custom_header_mobile-actions">
                    {% render 'custom_header_mobile_actions' %}
                </div>
        </div>
    </div>
</header>

<style>
.custom_header_container{
    width: 100%;
    height: 100%;
    max-width: 1240px;
}
.custom_header_wrapper{
    display: flex;
    align-items: center;
    width: 100%;
    height: 100%;
}
.custom_header_navigation{
    width: 100%;
    height: 100%;
    max-width: 935px;
}

</style>
{%  schema  %} 
{
    "name": "Custom Header",
    "class": "custom_header",
    "disabled_on": {
        "groups": ["footer", "aside"]
    },
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color Scheme",
            "default": "scheme-5"
        },
        {
            "type": "link_list",
            "id": "custom_menu",
            "label": "Header Menu"
        },
        {
            "type": "image_picker",
            "id": "header_logo",
            "label": "Header Logo"
        },
        {
        "type": "range",
        "id": "header_logo_width",
        "label": "Logo Width",
        "min": 80,
        "max": 180,
        "step": 1,
        "default": 107,
        "unit": "px"
        },
        {
        "type": "range",
        "id": "header_logo_height",
        "label": "Logo Height",
        "min": 30,
        "max": 130,
        "step": 1,
        "default": 65,
        "unit": "px"
        }
    ]
}
{% endschema %}