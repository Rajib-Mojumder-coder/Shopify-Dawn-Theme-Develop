{%liquid
  assign color_scheme = section.settings.color_scheme
%}
<div class="color-{{ color_scheme }} gradient">Hello

</div>

{%  schema  %} 
{
    "name": "Custom Header",
    "class": "custom_header",
    "disabled_on": {
        "groups": ["footer", "aside"]
    },
    "settings": [
    {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color Scheme",
        "default": "scheme-5"
    }
    ]
}
{% endschema %}