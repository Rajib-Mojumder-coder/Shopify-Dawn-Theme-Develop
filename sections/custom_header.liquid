{%liquid
  assign color_scheme = section.settings.color_scheme
  assign header_logo_width = section.settings.header_logo_width
  assign header_logo_height = section.settings.header_logo_height
%}
<header class="custom_header color-{{ color_scheme }} gradient"
 style="--header-logo-width: {{ header_logo_width }}px; --header-logo-height: {{ header_logo_height }}px;"
>
    <div class="page-width custom_header_container">
        <div class="custom_header_inner">
                <div class="custom_header_branding">
                    {% render 'custom_header_logo' %}
                </div>

                <div class="custom_header_navigation">
                    {% render 'custom_header_navigation' %}
                </div>

                <div class="custom_header_actions">
                    {% render 'custom_header_actions' %}
                </div>

                <div class="custom_header_mobile_actions">
                    {% render 'custom_header_mobile_actions' %}
                </div>
        </div>
    </div>
</header>

<style>
    .custom_header{
    position: relative;
    z-index: 100;
}
.custom_header_container{
    width: 100%;
    height: 100%;
    max-width: 1240px;
}
.custom_header_inner{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:40px;
    min-height:90px;
}
.custom_header_branding{
    flex:0 0 auto;
    width:var(--header-logo-width);
    height:var(--header-logo-height);
}

.custom_header_navigation{
    flex:1 1 auto;
    min-width:0;
    position:relative;
}

.custom_header_actions{
    flex:0 0 auto;
}

.custom_header_mobile_actions{
    display:none;
}

</style>
{%  schema  %} 
{
    "name": "Custom Header",
    "class": "custom_header",
    "disabled_on": {
        "groups": ["footer", "aside"]
    },
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color Scheme",
            "default": "scheme-5"
        },
        {
            "type": "link_list",
            "id": "custom_menu",
            "label": "Header Menu"
        },
        {
            "type": "image_picker",
            "id": "header_logo",
            "label": "Header Logo"
        },
        {
        "type": "range",
        "id": "header_logo_width",
        "label": "Logo Width",
        "min": 80,
        "max": 180,
        "step": 1,
        "default": 107,
        "unit": "px"
        },
        {
        "type": "range",
        "id": "header_logo_height",
        "label": "Logo Height",
        "min": 30,
        "max": 130,
        "step": 1,
        "default": 65,
        "unit": "px"
        }
        
    ],
    "blocks": [
        {
            "type": "custom_mega_menu",
            "name": "Mega Menu",
            "settings": [
                {
                "type": "text",
                "id": "menu_handle",
                "label": "Menu Handle"
                },
                {
                "type": "text",
                "id": "heading",
                "label": "Heading"
                },
                {
                "type": "image_picker",
                "id": "promo_image",
                "label": "Promotion Image"
                },
                {
                "type": "text",
                "id": "promo_title",
                "label": "Promotion Title"
                },
                {
                "type": "text",
                "id": "button_text",
                "label": "Button Text"
                },
                {
                "type": "url",
                "id": "button_link",
                "label": "Button Link"
                },
                {
                "type": "color",
                "id": "button_color",
                "label": "Button Color",
                "default": "#58B7A5"
                },
                {
                "type": "text",
                "id": "featured_collection_handle",
                "label": "Featured Collection Handle"
                }
            ]
        }
    ]
}
{% endschema %}

{%  comment  %}  
    overall full menu both desktop & mobile device found some different.
    overview all menu items found there don't have any link level== 2, which reffered megamenu, instead of this link level ==2 are act both dropdown & megamenu.
{% endcomment %} 