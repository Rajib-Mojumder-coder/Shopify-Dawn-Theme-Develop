{%liquid
  assign color_scheme = section.settings.color_scheme
  assign custom_menu = section.settings.header_menu
  assign header_logo = section.settings.header_logo
%}
<header class="custom_header color-{{ color_scheme }} gradient">
    <div class="page-width custom_header_container">
        <div class="custom_header_wrapper">
                <div class="custom_header_branding">
                    {% render 'custom_header_logo' %}
                </div>

                <div class="custom_header_navigation">
                    {% render 'custom_header_navigation' %}
                </div>

                <div class="custom_header_actions">
                    {% render 'custom_header_actions' %}
                </div>

                <div class="custom_header_mobile-actions">
                    {% render 'custom_header_mobile_actions' %}
                </div>
        </div>
    </div>
</header>

<style>
.custom_header_container{
    width: 100%;
    height: 100%;
    max-width: 1240px;
}
.custom_header_wrapper{
    display: flex;
    width: 100%;
    height: 100%;
}


</style>
{%  schema  %} 
{
    "name": "Custom Header",
    "class": "custom_header",
    "disabled_on": {
        "groups": ["footer", "aside"]
    },
    "settings": [
    {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color Scheme",
        "default": "scheme-5"
    },
    {
        "type": "link_list",
        "id": "custom_menu",
        "label": "Header Menu"
    },
    {
        "type": "image_picker",
        "id": "header_logo",
        "label": "Logo"
    }
    ]
}
{% endschema %}