{% comment %} <div class="cbs-{{ section.id }}">

  <!-- BACKGROUND -->
  <div class="cbs-bg">  </div>

  <!-- OVERLAY -->
  <div class="cbs-overlay">  </div>

  <!-- CONTENT -->
  <div class="cbs-inner">

    <div class="page-width">
      <div class="cbs-blocks">
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</div> {% endcomment %}

{{ 'custom-block-section.css' | asset_url | stylesheet_tag }}

{% liquid
  assign custom_layout_type    = section.settings.custom_layout_type
  assign layout_max_width    = section.settings.layout_max_width
  
  assign color_scheme        = section.settings.color_scheme
  assign background_media        = section.settings.background_media
  assign background_image        = section.settings.background_image
  assign background_image_position        = section.settings.background_image_position
  assign background_overlay        = section.settings.background_overlay

  assign padding_top         = section.settings.padding_top
  assign padding_bottom      = section.settings.padding_bottom

  assign desktop_layout      = section.settings.desktop_layout
  assign desktop_direction   = section.settings.desktop_direction
  assign desktop_wrap        = section.settings.desktop_wrap
  assign desktop_justify  = section.settings.desktop_justify
  assign desktop_align     = section.settings.desktop_align
  assign desktop_columns          = section.settings.desktop_columns
  assign desktop_gap              = section.settings.desktop_gap

  assign mobile_layout     = section.settings.mobile_layout
  assign mobile_direction  = section.settings.mobile_direction
  assign mobile_wrap       = section.settings.mobile_wrap
  assign mobile_justify    = section.settings.mobile_justify
  assign mobile_align      = section.settings.mobile_align
  assign mobile_columns         = section.settings.mobile_columns
  assign mobile_gap             = section.settings.mobile_gap
%}
<style>
   .cbs-{{ section.id }}{
    position: relative;
    overflow: hidden;
  isolation: isolate;
    padding : {{ padding_top }}px 0 {{ padding_bottom }}px 0;
    --desktop-gap: {{ desktop_gap }}px;
    --mobile-gap: {{ mobile_gap }}px;

    --desktop-columns: {{ desktop_columns }};
    --mobile-columns: {{ mobile_columns }};
     {% case section.settings.section_height_mode %}
      {% when 'preset' %}
        {% case section.settings.preset_height %}
          {% when 'small' %}
            min-height: clamp(320px, 40vh, 500px);
          {% when 'medium' %}
            min-height: clamp(450px, 60vh, 800px);
          {% when 'large' %}
            min-height: clamp(600px, 80vh, 1100px);
          {% when 'fullscreen' %}
            min-height: 100vh;
        {% endcase %}

      {% when 'custom' %}
        min-height:
          clamp(
            {{ section.settings.custom_min_height }}px,
            {{ section.settings.custom_viewport_height }}vh,
            {{ section.settings.custom_max_height }}px
          );
      {% else %}
        min-height: auto;
    {% endcase %}
  }
/* ====BACKGROUND======= */

.cbs-{{ section.id }} .cbs-bg{
  position: absolute;
  inset: 0;
  z-index: -3;
}

.cbs-{{ section.id }} .cbs-bg-image,
.cbs-{{ section.id }} .cbs-bg-video{
  width: 100%;
  height: 100%;
  object-fit: {{ background_image_position }};
}

/* =========OVERLAY======= */

.cbs-{{ section.id }} .cbs-overlay{
  position: absolute;
  inset: 0;
  z-index: -2;
  background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
}
  /* ===== CONTAINER WIDTH SYSTEM ========= */
 .cbs-{{ section.id }} .cbs-container--custom{
    max-width: {{ layout_max_width }};
  }

  .cbs-{{ section.id }} .cbs-container--full{
    max-width: 100%;
  }
    /* ======= BLOCKS BASE============ */

  .cbs-{{ section.id }} .cbs-blocks{
    width: 100%;
  }

   /* ======DESKTOP========== */

  @media screen and (min-width: 768px){
    .cbs-{{ section.id }} .cbs-blocks{
      gap: var(--desktop-gap);
      {% if desktop_layout == 'flex' %}
      display: flex;
      flex-direction: {{ desktop_direction }};
      flex-wrap: {{ desktop_wrap }};
      justify-content: {{ desktop_justify }};
      align-items: {{ desktop_align }};
       {% else %}
      display: grid;
      grid-template-columns: repeat(var(--desktop-columns), minmax(0,1fr));
        justify-content: {{ desktop_justify }};
        align-items: {{ desktop_align }};
      {% endif %}
    }
  }

  /* =======MOBILE========*/

  @media screen and (max-width: 767px){

    .cbs-{{ section.id }} .cbs-blocks{
      gap: var(--mobile-gap);
      {% if mobile_layout == 'flex' %}
        display: flex;
        flex-direction:  {{ mobile_direction }};
        flex-wrap:       {{ mobile_wrap }};
        justify-content:    {{ mobile_justify }};
        align-items:  {{ mobile_align }};
      {% else %}
        display: grid;
        grid-template-columns: repeat( var(--mobile-columns), minmax(0,1fr));
        justify-content: {{ mobile_justify }};
        align-items: {{ mobile_align }};
      {% endif %}
    }
  }
</style>

<div class="cbs-{{ section.id }} color-{{ color_scheme }}">
  <!-- BACKGROUND -->
   <div class="cbs-bg">
      {% if background_media == 'image' and background_image != blank %}
      <img src="{{ background_image | image_url: width: 3500 }}" alt="" class="cbs-bg-image">
    {% elsif background_media == 'video' and section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'cbs-bg-video'
      }}
    {% endif %}
   </div>

   <!-- OVERLAY -->
  {% if background_overlay %}
    <div class="cbs-overlay"></div>
  {% endif %}
  <div class="page-width {% if custom_layout_type != 'default' %} cbs-container--{{ custom_layout_type }}{% endif %}">
    <div class="cbs-blocks">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% comment %} <div class="cbs-{{ section.id }} color-{{ section.settings.color_scheme }}">

  <!-- BACKGROUND -->
  <div class="cbs-bg">

    {% if section.settings.background_media == 'image' and section.settings.background_image != blank %}

      <img
        src="{{ section.settings.background_image | image_url: width: 2500 }}"
        alt=""
        class="cbs-bg-image"
      >

    {% elsif section.settings.background_media == 'video' and section.settings.video != blank %}

      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'cbs-bg-video'
      }}

    {% endif %}

  </div>

  <!-- OVERLAY -->
  {% if section.settings.enable_overlay %}
    <div class="cbs-overlay"></div>
  {% endif %}

  <!-- CONTENT -->
  <div class="cbs-inner">

    <div class="
      page-width
      {% if section.settings.custom_layout_type == 'custom' %}
        cbs-page-width-custom
      {% else %}
        cbs-page-width-full
      {% endif %}
    ">

      <div class="cbs-blocks">
        {% content_for 'blocks' %}
      </div>

    </div>

  </div>

</div> {% endcomment %}

{% schema %}
{
  "name": "Custom Block Section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Size"
    },
    {
      "type": "select",
      "id": "custom_layout_type",
      "label": "Layout Type",
      "options": [
        {"value": "custom", "label": "Custom"},
        {"value": "full", "label": "Full"}
      ],
      "default": "full"
    },
    {
      "type": "text",
      "id": "layout_max_width",
      "label": "Layout Max Width (px/%)",
      "default": "1728px",
      "info": "Leave blank to use theme default width.",
      "visible_if": "{{ section.settings.custom_layout_type == 'custom'}}"
    },
    {
      "type": "select",
      "id": "section_height_mode",
      "label": "Height",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "preset", "label": "Preset" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
      {
    "type": "select",
    "id": "preset_height",
    "label": "Preset Height",
    "options": [
      { "value": "small", "label": "Small" },
      { "value": "medium", "label": "Medium" },
      { "value": "large", "label": "Large" },
      { "value": "fullscreen", "label": "Full Screen" }
    ],
    "default": "medium",
    "visible_if": "{{section.settings.section_height_mode == 'preset' }}"
  },
  {
  "type": "range",
  "id": "custom_min_height",
  "label": "Minimum Height",
  "min": 200,
  "max": 1200,
  "step": 20,
  "unit": "px",
  "default": 400,
  "visible_if": "{{section.settings.section_height_mode == 'custom' }}"
},
{
  "type": "range",
  "id": "custom_viewport_height",
  "label": "Viewport Height (%)",
  "min": 10,
  "max": 100,
  "step": 5,
  "unit": "vh",
  "default": 60,
  "visible_if": "{{section.settings.section_height_mode == 'custom' }}"
},
{
  "type": "range",
  "id": "custom_max_height",
  "label": "Maximum Height",
  "min": 300,
  "max": 1600,
  "step": 20,
  "unit": "px",
  "default": 900,
  "visible_if": "{{section.settings.section_height_mode == 'custom' }}"
},
{
  "type": "header",
  "content": "Padding"
},
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Spacing",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
{
  "type": "header",
  "content": "Apparance"
},
{
  "type": "color_scheme",
  "id": "color_scheme",
  "label": "Color Scheme",
  "default": "scheme-1"
},
 {
      "type": "select",
      "id": "background_media",
      "label": "Background Media",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "none"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ section.settings.background_media == 'video' }}"
    },
    {
      "type": "select",
      "id": "video_position",
      "label": "Video Position",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'video' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image",
      "visible_if": "{{ section.settings.background_media == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "fit",
          "label": "Fit"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_media == 'image' }}"
    },
{
  "type": "checkbox",
  "id": "background_overlay",
  "label": "Background Overlay",
  "default": false
},
{
  "type": "color",
  "id": "overlay_color",
  "label": "Overlay Color",
  "alpha": true,
  "visible_if": "{{ section.settings.background_overlay == true }}"
},
{
"type": "header",
"content": "Layout"
},
{
"type": "select",
"id": "layout_options",
"label": "Layout Options",
"options": [
  { "label": "Desktop", "value": "desktop_layout"},
  { "label": "Mobile", "value": "mobile_layout"}
]
},
{
  "type": "select",
  "id": "desktop_layout",
  "label": "Layout Type",
  "options": [
    { "value": "flex", "label": "Flex" },
    { "value": "grid", "label": "Grid" }
  ],
  "default": "flex",
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' }}"
},
{
  "type": "select",
  "id": "desktop_direction",
  "label": "Flex Direction",
  "options": [
    { "value": "row", "label": "Row" },
    { "value": "column", "label": "Column" }
  ],
  "default": "row",
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' and section.settings.desktop_layout == 'flex' }}"
},
{
  "type": "select",
  "id": "desktop_wrap",
  "label": "Flex Wrap",
  "options": [
    { "value": "nowrap", "label": "No Wrap" },
    { "value": "wrap", "label": "Wrap" }
  ],
  "default": "wrap",
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' and section.settings.desktop_layout == 'flex' }}"
},
{
  "type": "range",
  "id": "desktop_columns",
  "label": "Grid Columns",
  "min": 1,
  "max": 6,
  "step": 1,
  "default": 3,
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' and section.settings.desktop_layout == 'grid' }}"
},
{
  "type": "select",
  "id": "desktop_justify",
  "label": "Horizontal Alignment",
  "options": [
    { "value": "flex-start", "label": "Start" },
    { "value": "center", "label": "Center" },
    { "value": "flex-end", "label": "End" },
    { "value": "space-between", "label": "Space Between" }
  ],
  "default": "flex-start",
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' }}"
},
{
  "type": "select",
  "id": "desktop_align",
  "label": "Vertical Alignment",
  "options": [
    { "value": "stretch", "label": "Stretch" },
    { "value": "flex-start", "label": "Top" },
    { "value": "center", "label": "Middle" },
    { "value": "flex-end", "label": "Bottom" }
  ],
  "default": "stretch",
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' }}"
},
{
  "type": "range",
  "id": "desktop_gap",
  "label": "Gap",
  "min": 0,
  "max": 80,
  "step": 4,
  "unit": "px",
  "default": 24,
  "visible_if": "{{ section.settings.layout_options == 'desktop_layout' }}"
},
{
  "type": "select",
  "id": "mobile_layout",
  "label": "Layout Type",
  "options": [
    { "value": "flex", "label": "Flex" },
    { "value": "grid", "label": "Grid" }
  ],
  "default": "flex",
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' }}"
},
{
  "type": "select",
  "id": "mobile_direction",
  "label": "Flex Direction",
  "options": [
    { "value": "row", "label": "Row" },
    { "value": "column", "label": "Column" }
  ],
  "default": "column",
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' and section.settings.mobile_layout == 'flex' }}"
},
{
  "type": "select",
  "id": "mobile_wrap",
  "label": "Flex Wrap",
  "options": [
    { "value": "nowrap", "label": "No Wrap" },
    { "value": "wrap", "label": "Wrap" }
  ],
  "default": "wrap",
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' and section.settings.mobile_layout == 'flex' }}"
},
{
  "type": "range",
  "id": "mobile_columns",
  "label": "Grid Columns",
  "min": 1,
  "max": 3,
  "step": 1,
  "default": 1,
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' and section.settings.mobile_layout == 'grid' }}"
},
{
  "type": "select",
  "id": "mobile_justify",
  "label": "Horizontal Alignment",
  "options": [
    { "value": "flex-start", "label": "Start" },
    { "value": "center", "label": "Center" },
    { "value": "flex-end", "label": "End" }
  ],
  "default": "flex-start",
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' }}"
},
{
  "type": "select",
  "id": "mobile_align",
  "label": "Vertical Alignment",
  "options": [
    { "value": "stretch", "label": "Stretch" },
    { "value": "flex-start", "label": "Top" },
    { "value": "center", "label": "Middle" },
    { "value": "flex-end", "label": "Bottom" }
  ],
  "default": "stretch",
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' }}"
},
{
  "type": "range",
  "id": "mobile_gap",
  "label": "Gap",
  "min": 0,
  "max": 40,
  "step": 4,
  "unit": "px",
  "default": 16,
  "visible_if": "{{ section.settings.layout_options == 'mobile_layout' }}"
}
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Custom Block Section"
    }
  ],
  "class": "custom-block-section",
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
