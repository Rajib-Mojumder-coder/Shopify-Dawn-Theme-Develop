<div class="swiper-slide">

    <div class="mega-slide">

        {% if block.settings.image %}

            <div class="mega-slide__image">

                {{
                    block.settings.image
                    | image_url: width: 520
                    | image_tag: loading: 'lazy'
                }}

            </div>

        {% endif %}

        {% if block.settings.button_text != blank %}

            <a
                href="{{ block.settings.button_link }}"
                class="mega-slide__button"
                style="
                    --btn-bg: {{ block.settings.button_bg }};
                    --btn-color: {{ block.settings.button_text_color }};
                "
            >
                {{ block.settings.button_text }}
            </a>

        {% endif %}

    </div>

</div>

<style>
    
.mega-slide{
    position:relative;
}

.mega-slide__image{
    position:relative;
    overflow:hidden;
    border-radius:32px 32px 200px 32px;
    background:#6F9A9A;
    transform:translateY(-35px);
}
</style>