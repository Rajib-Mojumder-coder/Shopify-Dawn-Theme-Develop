<div id="mobile-drawer" class="custom-mobile-drawer" aria-hidden="true">

    <div class="custom-mobile-drawer__overlay" data-drawer-close> &nbsp; </div>

    <aside class="custom-mobile-drawer__panel">

        {% render 'custom_mobile_drawer_header' %}

        <div class="custom-mobile-drawer__content">

                <section class="custom-mobile-drawer__main" data-panel="main">
                    {% render 'custom_mobile_menu', menu: section.settings.custom_main_menu %}
                    {% render 'custom-mobile-social' %}
                </section>

                <section class="custom-mobile-drawer__submenu" data-panel="submenu">
                    {% render 'custom_mobile_submenu_panel' %}
                </section>

        </div>

    </aside>

</div> 

<style>
.custom-mobile-drawer{
position:fixed;
inset:0;
z-index:999;
visibility:hidden;
pointer-events:none;
}

.custom-mobile-drawer.is-open{
visibility:visible;
pointer-events:auto;
}

/*Overlay*/
.custom-mobile-drawer__overlay{
position:absolute;
inset:0;
background:rgba(0,0,0,.45);
opacity:0;
transition:.3s;
}

.custom-mobile-drawer.is-open
.custom-mobile-drawer__overlay{
opacity:1;
}

/*Panel*/
.custom-mobile-drawer__panel{
position:absolute;
left:0;
top:0;
height: 100dvh;
max-width: 100%;
width: 100%;
/* width:min(92vw,380px); */
/* background:#061444; */
transform:translateX(-100%);
transition:transform .35s ease;
display:flex;
flex-direction:column;
}

.custom-mobile-drawer__content{
position:relative;
flex:1;
min-height: 0;
overflow:hidden;
width: min(92vw, 450px);
border-bottom-left-radius:52px;
border-bottom-right-radius:52px;
}

.custom-mobile-drawer__main,
.custom-mobile-drawer__submenu{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
overflow-y:auto;
background:#0A1A42;
transition: transform .38s cubic-bezier(.25,.8,.25,1);
}

/*Initially*/
.custom-mobile-drawer__main{
transform:translateX(0);
}
.custom-mobile-drawer__submenu{
transform:translateX(100%);
}
/*When Open*/
.custom-mobile-drawer.show-submenu
.custom-mobile-drawer__main{
transform:translateX(-100%);
}

.custom-mobile-drawer.show-submenu
.custom-mobile-drawer__submenu{
transform:translateX(0);
}

.custom-mobile-drawer.is-open
.custom-mobile-drawer__panel{
transform:translateX(0);
}
</style>