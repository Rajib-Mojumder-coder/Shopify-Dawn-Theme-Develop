<div class="mega-menu-items">

{% for child in parent.links %}

    {% assign collection = child.object %}

    <a href="{{ child.url }}" class="mega-menu-item">

        <div class="mega-menu-item__icon">

            {% if collection and collection.metafields.custom.menu_icon %}

                {{
                    collection.metafields.custom.menu_icon
                    | image_url: width: 48
                    | image_tag
                }}

            {% endif %}

        </div>

        <div class="mega-menu-item__titleicon">
            <span>{{ child.title }}</span>
            <span class="hover-icon">  <img src="{{ 'forward-slash-icon.svg' | asset_url }}" alt=""> </span>
        </div>
    </a>

{% endfor %}

</div>



<style>
    .mega-menu-items{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:10px 14px;
}

.mega-menu-item{
    display:flex;
    align-items:center;
    gap:16px;
    text-decoration:none;
    color:#fff;
    width: fit-content;
    background: transparent;
    border-radius: 200px;
}

.mega-menu-item__icon{
    width: 46px;
    height: 46px;
    max-width: 100%;
    max-height: 100%;
    border-radius:50%;
    border:1px solid rgba(255,255,255,.25);
    display:flex;
    justify-content:center;
    align-items:center;
    flex-shrink:0;
    padding: 7px;
}

.mega-menu-item__icon > img{
    width:100%;
    height:100%;
    object-fit: scale-down;
    max-width: 30px;
}
.mega-menu-item__titleicon{
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    gap: 4px;
}
span.hover-icon{
    display: flex;
    align-items: center;
    max-width: 100% ;
    width: 19px;
    height: 100%;
    position: relative;
}
.hover-icon img{
    position: absolute;
    width: 100%;
    height: 100%;
    left: -10px;
    opacity: 0;
    visibility: hidden;
    transition: ease 0.3s;
}
/*HOVER*/
.mega-menu-item{
    transition:.3s;
}

.mega-menu-item:hover
.mega-menu-item
{
    background:#020922 !important;
}

.mega-menu-item:hover
.hover-icon img{
    opacity: 1;
    visibility: visible;
    left: 0px;
}
</style>