{% liquid
  assign logo = section.settings.header_logo
  assign logo_alt = shop.name
%}

<a
  href="{{ routes.root_url }}"
  class="custom-header_logo"
  aria-label="{{ shop.name }}"
>

  {% if logo != blank %}
    {{
      logo
      | image_url: width: 214
      | image_tag:
        widths: '107,160,214',
        loading: 'eager',
        class: 'custom-header_logo-image',
        alt: logo_alt
    }}
  {% else %}
    <span class="custom-header_logo-text">
      {{ shop.name }}
    </span>
  {% endif %}

</a>

<style>
    .custom_header_branding{
        display:flex;
        align-items:center;
        flex-shrink:0;
        width:var(--header-logo-width);
        height:var(--header-logo-height);
    }

    .custom-header_logo{
        display:flex;
        align-items:center;
        justify-content:center;
        max-width: 107px;
        width:100%;
        height:100%;
        flex-shrink: 0;
        text-decoration:none;
    }
    .custom-header_logo-image{
        width:100%;
        height:100%;
    }
</style>