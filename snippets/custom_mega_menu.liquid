{%  liquid  
assign mega_heading = block.settings.heading
%}

<div class="custom-mega-menu">
    
    <div class="custom-mega-menu__left">
        <p class="mega_title"> {{ mega_heading }}</p>

        {% render 'custom_mega_menu_items',
            parent: parent,
            mega_block: mega_block
        %}

    </div>

    <div class="custom-mega-menu__right">

        {% render 'custom_mega_menu_slider',
            mega_block: mega_block,
            section: section
        %}

    </div>
 
</div>

