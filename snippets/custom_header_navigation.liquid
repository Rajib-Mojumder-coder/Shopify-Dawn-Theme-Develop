
{%liquid
    assign main_menu = section.settings.custom_menu
 %}

<ul class="custom_main_menu">
    
    {% for parent in main_menu.links %}
        {% if parent.levels == 0 %}
            <li class="main_menu_item {{link.handle}} {% if parent.active %}active{% endif %}"> 
                <a href="{{parent.url}}"> {{parent.title}} </a>
            </li>
        {%  elsif parent.levels == 1 %}
            <li class="dropdown_menu main_menu_item {% if parent.active %}active{% endif %}"> 
                <span> {{parent.title}} </span>
                <div class="dropdown_menu_main"> 
                    <div class="dropdown_menu_container">

                        <div class="dropdown_menu_items">
                            {% for child in parent.links %}
                            <a href="{{child.url}}" class="{% if child.active %}active{% endif %}"> {{child.title}} </a>
                            {% endfor %}
                        </div>
                        <div> Slider </div>

                    </div>
                </div>
            </li>
        {%  else parent.levels == 2 %}
            <li class="mega_menu main_menu_item {% if parent.active %}active{% endif %}"> 
                <span>  </span>
            </li>
        {% endif %}
    {% endfor %}

</ul>

<style>
    .custom_header_navigation .custom_main_menu{
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
    }
   .custom_header_navigation ul{
        margin: 0;
        padding: 0;
    }
   .custom_header_navigation li{
        list-style: none;
    }
    .custom_header_navigation a{
        text-decoration: none;
    }
    .custom_header_navigation .main_menu_item{
        display: block;
        padding: 5px;
        border-radius: 5px;
    }
    .custom_header_navigation .main_menu_item a, span{
        color: #fff;
    }
    
    .custom_main_menu .dropdown_menu{
        width: 100%;
        height: 100%;
    }
    .custom_main_menu .dropdown_menu_main{
        width: 100%;
        height: 100%;
        max-width: 1200px;
        position: absolute;
        left: 0;
        top: 100%;
     min-height: 250px;
    }
    .custom_main_menu .dropdown_menu_container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 90%;
    height: 100%;
    margin: 0 auto;
    padding-inline: 50px;
    padding-block: 40px;
    background: orangered;
    }
    .dropdown_menu_items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100%;
    }
</style>