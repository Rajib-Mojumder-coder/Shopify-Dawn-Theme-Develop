{% liquid
    assign main_menu = section.settings.custom_menu
%}

<ul class="custom-main-menu">

    {% for parent in main_menu.links %}

        {% liquid
            assign mega_block = blank

            for block in section.blocks

                if block.type == 'mega_menu'
                    if block.settings.menu_handle == parent.handle
                        assign mega_block = block
                        break
                    endif
                endif

            endfor
        %}

        <li class="custom-main-menu__item{% if mega_block != blank %} has-mega{% endif %}">

            <a
                href="{{ parent.url }}"
                class="custom-main-menu__link {% if parent.active %}is-active{% endif %}"
            >
                {{ parent.title }}
            </a>

            {% if mega_block != blank %}
                {% render 'custom_mega_menu',
                    block: mega_block
                %}
            {% endif %}

        </li>

    {% endfor %}

</ul>

<style>
    .custom_header_navigation .custom_main_menu{
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 40px;
        margin: 0;
        padding: 0;
    }
   .custom_header_navigation ul{
        margin: 0;
        padding: 0;
    }
   .custom_header_navigation li{
        list-style: none;
    }
    .custom_header_navigation a{
        text-decoration: none;
    }
    .custom_header_navigation .main_menu_item{
        position:relative;
        flex:0 0 auto;
        padding: 5px;
        border-radius: 5px;
    }
    .custom_header_navigation .main_menu_item a, span{
        color: #fff;
    }
    
    .custom_main_menu .dropdown_menu{
        height: 100%;
    }
    .custom_main_menu .dropdown_menu_main{
        width: 100%;
        height: 100%;
        max-width: 1200px;
        position: absolute;
        left: 0;
        top: 100%;
     min-height: 250px;
    }
    .custom_main_menu .dropdown_menu_container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 90%;
    height: 100%;
    margin: 0 auto;
    padding-inline: 50px;
    padding-block: 40px;
    background: orangered;
    }
    .dropdown_menu_items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100%;
    }
</style>