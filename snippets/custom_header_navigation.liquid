
{%liquid
    assign main_menu = section.settings.custom_menu
 %}

<ul class="custom_main_menu">
    
    {% for link in main_menu.links %}
        <li class="main_menu_list {{link.handle}}"> 
            <a href="{{link.url}}" class="{{link.active}}"> {{link.title}} </a>
        </li>
    {% endfor %}

</ul>

<style>
   .custom_header_navigation ul{
        margin: 0;
        padding: 0;
    }
   .custom_header_navigation li{
        list-style: none;
    }
    .custom_header_navigation a{
        text-decoration: none;
    }
    .custom_header_navigation .custom_main_menu{
        display: flex;
        width: 100%;
        height: 100%; 
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }
</style>