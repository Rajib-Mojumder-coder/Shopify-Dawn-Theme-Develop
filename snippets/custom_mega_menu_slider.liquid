<div class="mega-slider swiper">
    <div class="swiper-wrapper">

        {% assign current_handle = mega_block.settings.menu_handle | handleize %}

        {% for block in section.blocks %}
            {% if block.type == 'mega_menu_slide' %}
                {% assign slide_handle = block.settings.menu_handle | handleize %}

                {% if slide_handle == current_handle %}
                    <div class="swiper-slide">
                        {% render 'advisor-card-content', advisor_block:block %}
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}

    </div>
    
    <div class="mega-slider__controls">

        <div class="swiper-button-prev"></div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>

    </div>
    

</div>





{% comment %} This is only slider without slider block
 
<div class="mega-slider swiper">
    <div class="swiper-wrapper">

        {% for i in (1..4) %}

            <div class="swiper-slide">
                <img src="https://picsum.photos/450/450?random={{ i }}"  alt="" >

                <h4>Slide {{ i }}</h4>
                <p> Demo text for the mega menu. </p>
            </div>

        {% endfor %}

    </div>

    <div class="swiper-pagination"></div>

</div>

<style>
    .mega-slider{
    width:100%;
    height:100%;
    overflow:hidden;
    border-radius:24px;
    max-width: 450px;
}

.mega-slider .swiper-slide{
    display:flex;
    flex-direction:column;
    gap:20px;
}

.mega-slider img{
    width:100%;
    border-radius:18px;
    aspect-ratio:1;
    object-fit:cover;
}

.mega-slider h4{
    color:#fff;
    margin:0;
    font-size:24px;
}

.mega-slider p{
    color:#d4d4d4;
    margin:0;
}

</style> {% endcomment %}