<div class="mega-slider swiper">
    <div class="swiper-wrapper">

        {% for i in (1..4) %}

            <div class="swiper-slide">
                <img src="https://picsum.photos/450/450?random={{ i }}"  alt="" >

                <h4>Slide {{ i }}</h4>
                <p> Demo text for the mega menu. </p>
            </div>

        {% endfor %}

    </div>

    <div class="swiper-pagination"></div>

</div>

<style>
    .mega-slider{
    width:100%;
    height:100%;
    overflow:hidden;
    border-radius:24px;
}

.mega-slider .swiper-slide{
    display:flex;
    flex-direction:column;
    gap:20px;
}

.mega-slider img{
    width:100%;
    border-radius:18px;
    aspect-ratio:1;
    object-fit:cover;
}

.mega-slider h4{
    color:#fff;
    margin:0;
    font-size:24px;
}

.mega-slider p{
    color:#d4d4d4;
    margin:0;
}

</style>