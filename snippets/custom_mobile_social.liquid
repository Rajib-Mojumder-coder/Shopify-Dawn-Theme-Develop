{% liquid
  assign has_social = false

  if settings.social_facebook_link != blank
    assign has_social = true
  elsif settings.social_instagram_link != blank
    assign has_social = true
  elsif settings.social_youtube_link != blank
    assign has_social = true
  elsif settings.social_tiktok_link != blank
    assign has_social = true
  elsif settings.social_x_link != blank
    assign has_social = true
  elsif settings.social_pinterest_link != blank
    assign has_social = true
  elsif settings.social_snapchat_link != blank
    assign has_social = true
  elsif settings.social_linkedin_link != blank
    assign has_social = true
  elsif settings.social_tumblr_link != blank
    assign has_social = true
  elsif settings.social_vimeo_link != blank
    assign has_social = true
  endif
%}

{% if has_social %}

<div class="custom-mobile-social">

    {% if settings.social_facebook_link != blank %}
        <a href="{{ settings.social_facebook_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="Facebook">

            {{ 'icon-facebook.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_instagram_link != blank %}
        <a href="{{ settings.social_instagram_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="Instagram">

            {{ 'icon-instagram.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_youtube_link != blank %}
        <a href="{{ settings.social_youtube_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="YouTube">

            {{ 'icon-youtube.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_x_link != blank %}
        <a href="{{ settings.social_x_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="X">

            {{ 'icon-x.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_linkedin_link != blank %}
        <a href="{{ settings.social_linkedin_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="LinkedIn">

            {{ 'icon-linkedin.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_pinterest_link != blank %}
        <a href="{{ settings.social_pinterest_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="Pinterest">

            {{ 'icon-pinterest.svg' | inline_asset_content }}

        </a>
    {% endif %}

    {% if settings.social_tiktok_link != blank %}
        <a href="{{ settings.social_tiktok_link }}"
           class="custom-mobile-social__item"
           target="_blank"
           rel="noopener"
           aria-label="TikTok">

            {{ 'icon-tiktok.svg' | inline_asset_content }}

        </a>
    {% endif %}

</div>

{% endif %}

